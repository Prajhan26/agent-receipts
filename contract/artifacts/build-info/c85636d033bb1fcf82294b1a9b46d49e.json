{"id":"c85636d033bb1fcf82294b1a9b46d49e","_format":"hh-sol-build-info-1","solcVersion":"0.8.24","solcLongVersion":"0.8.24+commit.e11b9ed9","input":{"language":"Solidity","sources":{"contracts/ReceiptAnchor.sol":{"content":"// SPDX-License-Identifier: MIT\npragma solidity ^0.8.24;\n\ncontract ReceiptAnchor {\n    struct Batch {\n        bytes32 merkleRoot;\n        uint256 receiptCount;\n        uint256 anchoredAt;\n    }\n\n    mapping(bytes32 => Batch) private _batches;\n\n    event BatchAnchored(\n        bytes32 indexed batchId,\n        bytes32 merkleRoot,\n        uint256 receiptCount,\n        uint256 anchoredAt\n    );\n\n    function anchorBatch(\n        bytes32 batchId,\n        bytes32 merkleRoot,\n        uint256 receiptCount\n    ) external {\n        require(_batches[batchId].anchoredAt == 0, \"batch already anchored\");\n        _batches[batchId] = Batch({\n            merkleRoot: merkleRoot,\n            receiptCount: receiptCount,\n            anchoredAt: block.timestamp\n        });\n        emit BatchAnchored(batchId, merkleRoot, receiptCount, block.timestamp);\n    }\n\n    function getBatchRoot(bytes32 batchId) external view returns (bytes32) {\n        return _batches[batchId].merkleRoot;\n    }\n}\n"}},"settings":{"optimizer":{"enabled":true,"runs":200},"evmVersion":"cancun","outputSelection":{"*":{"*":["abi","evm.bytecode","evm.deployedBytecode","evm.methodIdentifiers","metadata"],"":["ast"]}}}},"output":{"sources":{"contracts/ReceiptAnchor.sol":{"ast":{"absolutePath":"contracts/ReceiptAnchor.sol","exportedSymbols":{"ReceiptAnchor":[76]},"id":77,"license":"MIT","nodeType":"SourceUnit","nodes":[{"id":1,"literals":["solidity","^","0.8",".24"],"nodeType":"PragmaDirective","src":"32:24:0"},{"abstract":false,"baseContracts":[],"canonicalName":"ReceiptAnchor","contractDependencies":[],"contractKind":"contract","fullyImplemented":true,"id":76,"linearizedBaseContracts":[76],"name":"ReceiptAnchor","nameLocation":"67:13:0","nodeType":"ContractDefinitio